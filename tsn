#!/bin/bash
# TSN CLI — compile TypeScript to native code
#
# Usage:
#   tsn build <file.ts|.tsx>         — optimized binary (-O2)
#   tsn build <file> --debug         — debug binary (-O0 -g, source maps)
#   tsn build <file> --platform ios  — select a non-default native host target
#   tsn run <file> --platform ios    — install + launch in iOS Simulator
#   tsn dev <file.ts|.tsx>           — watch mode, auto-recompile + relaunch
#   tsn run <file.ts|.tsx>           — compile + run once

set -e
DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  build)
    shift
    npx tsx "$DIR/compiler/index.ts" "$@"
    ;;
  dev)
    shift
    npx tsx "$DIR/compiler/dev.ts" "$@"
    ;;
  run)
    shift
    npx tsx "$DIR/compiler/run.ts" "$@"
    ;;
  inspect)
    shift
    npx tsx "$DIR/compiler/inspect.ts" "$@"
    ;;
  *)
    echo "TSN — TypeScript Native compiler"
    echo ""
    echo "Usage:"
    echo "  tsn build <file.ts|.tsx>               Compile to optimized binary"
    echo "  tsn build <file> --debug               Compile with debug symbols + bounds checking"
    echo "  tsn build <file> --platform ios        Select a non-default native host target"
    echo "  tsn dev <file.ts|.tsx>                 Watch mode with auto-recompile"
    echo "  tsn run <file.ts|.tsx>                 Compile and run"
    echo "  tsn run <file> --platform ios          Install and launch the built app in iOS Simulator"
    echo "  tsn run <file> --platform ios --simulator \"iPhone 17 Pro\""
    echo "  tsn inspect tree                       Dump view hierarchy of running app"
    echo "  tsn inspect find <text>                Find elements containing text"
    echo "  tsn inspect get <id> [prop]            Get element property"
    echo "  tsn inspect screenshot                 Save screenshot to /tmp"
    echo "  tsn inspect click <label>              Click a button"
    echo "  tsn inspect type <text>                Type into search field"
    echo ""
    ;;
esac
