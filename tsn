#!/bin/bash
# TSN CLI — compile TypeScript to native code
#
# Usage:
#   tsn build <file.ts>              — optimized binary (-O2)
#   tsn build <file> --debug         — debug binary (-O0 -g, source maps)
#   tsn dev <file.ts>                — watch mode, auto-recompile + relaunch
#   tsn run <file.ts>                — compile + run once

set -e
DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  build)
    shift
    npx tsx "$DIR/compiler/index.ts" "$@"
    ;;
  dev)
    shift
    npx tsx "$DIR/compiler/dev.ts" "$@"
    ;;
  run)
    shift
    npx tsx "$DIR/compiler/index.ts" "$@"
    BASE="$(basename "${1}")"
    BASE="${BASE%.tsx}"
    BASE="${BASE%.ts}"
    BINARY="build/$BASE"
    "./$BINARY"
    ;;
  *)
    echo "TSN — TypeScript Native compiler"
    echo ""
    echo "Usage:"
    echo "  tsn build <file.ts>                    Compile to optimized binary"
    echo "  tsn build <file> --debug               Compile with debug symbols + bounds checking"
    echo "  tsn dev <file.ts>                      Watch mode with auto-recompile"
    echo "  tsn run <file.ts>                      Compile and run"
    echo ""
    ;;
esac
