{
  "name": "tsn-native",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "Compile strict TypeScript to native binaries via C",
  "type": "module",
  "scripts": {
    "bench": "bash harness/run-benchmarks.sh",
    "test": "npm run test:unit && bash harness/correctness.sh && bash harness/ui-conformance.sh",
    "test:unit": "npm run test:tailwind && npm run test:compiler",
    "test:tailwind": "npx tsx --test packages/tsn-tailwind/src/index.test.ts",
    "test:compiler": "npx tsx --test packages/tsn-compiler-core/test/**/*.test.ts",
    "test:compiler:coverage": "npx tsx --test --experimental-test-coverage packages/tsn-compiler-core/test/**/*.test.ts",
    "test:cli": "bash harness/correctness.sh",
    "test:ui": "bash harness/ui-conformance.sh",
    "compile": "node --loader ts-node/esm compiler/index.ts"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.0"
  }
}
